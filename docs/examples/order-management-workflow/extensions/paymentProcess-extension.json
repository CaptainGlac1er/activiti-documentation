{
  "id": "paymentProcess",
  "name": "Payment Process",
  "type": "PROCESS",
  "extensions": {
    "Process_paymentProcess": {
      "properties": {
        "orderId-id": {
          "id": "orderId-id",
          "name": "orderId",
          "type": "string",
          "required": true,
          "value": ""
        },
        "amount-id": {
          "id": "amount-id",
          "name": "amount",
          "type": "bigdecimal",
          "required": true,
          "value": 0
        },
        "customerEmail-id": {
          "id": "customerEmail-id",
          "name": "customerEmail",
          "type": "string",
          "required": true,
          "value": ""
        },
        "paymentMethod-id": {
          "id": "paymentMethod-id",
          "name": "paymentMethod",
          "type": "string",
          "required": false,
          "value": ""
        },
        "cardNumber-id": {
          "id": "cardNumber-id",
          "name": "cardNumber",
          "type": "string",
          "required": false,
          "value": ""
        },
        "paymentValid-id": {
          "id": "paymentValid-id",
          "name": "paymentValid",
          "type": "boolean",
          "required": false,
          "value": false
        },
        "paymentSuccess-id": {
          "id": "paymentSuccess-id",
          "name": "paymentSuccess",
          "type": "boolean",
          "required": false,
          "value": false
        },
        "paymentStatus-id": {
          "id": "paymentStatus-id",
          "name": "paymentStatus",
          "type": "string",
          "required": false,
          "value": "PENDING"
        },
        "paymentDetails-id": {
          "id": "paymentDetails-id",
          "name": "paymentDetails",
          "type": "json",
          "required": false,
          "value": {}
        },
        "retryCount-id": {
          "id": "retryCount-id",
          "name": "retryCount",
          "type": "integer",
          "required": false,
          "value": 0
        },
        "retryAttempts-id": {
          "id": "retryAttempts-id",
          "name": "retryAttempts",
          "type": "json",
          "required": false,
          "value": [1, 2, 3]
        },
        "retryValid-id": {
          "id": "retryValid-id",
          "name": "retryValid",
          "type": "boolean",
          "required": false,
          "value": false
        },
        "approvedRetries-id": {
          "id": "approvedRetries-id",
          "name": "approvedRetries",
          "type": "integer",
          "required": false,
          "value": 0
        },
        "receiptNumber-id": {
          "id": "receiptNumber-id",
          "name": "receiptNumber",
          "type": "string",
          "required": false,
          "value": ""
        }
      },
      "mappings": {
        "enterPaymentDetailsTask": {
          "inputs": {
            "orderId": {
              "type": "variable",
              "value": "orderId"
            },
            "amount": {
              "type": "variable",
              "value": "amount"
            },
            "customerEmail": {
              "type": "variable",
              "value": "customerEmail"
            }
          },
          "outputs": {
            "paymentMethod": {
              "type": "variable",
              "value": "paymentMethod"
            },
            "cardNumber": {
              "type": "variable",
              "value": "cardNumber"
            }
          }
        },
        "validatePaymentMethodTask": {
          "inputs": {
            "paymentMethod": {
              "type": "variable",
              "value": "paymentMethod"
            },
            "cardNumber": {
              "type": "variable",
              "value": "cardNumber"
            },
            "amount": {
              "type": "variable",
              "value": "amount"
            }
          },
          "outputs": {
            "paymentValid": {
              "type": "variable",
              "value": "isValid"
            },
            "validationErrors": {
              "type": "variable",
              "value": "errors"
            }
          }
        },
        "processPaymentTask": {
          "inputs": {
            "orderId": {
              "type": "variable",
              "value": "orderId"
            },
            "amount": {
              "type": "variable",
              "value": "amount"
            },
            "paymentMethod": {
              "type": "variable",
              "value": "paymentMethod"
            },
            "cardNumber": {
              "type": "variable",
              "value": "cardNumber"
            },
            "customerEmail": {
              "type": "variable",
              "value": "customerEmail"
            }
          },
          "outputs": {
            "paymentSuccess": {
              "type": "variable",
              "value": "success"
            },
            "paymentStatus": {
              "type": "variable",
              "value": "status"
            },
            "paymentDetails": {
              "type": "variable",
              "value": "transactionDetails"
            }
          }
        },
        "retryPaymentTask": {
          "inputs": {
            "orderId": {
              "type": "variable",
              "value": "orderId"
            },
            "amount": {
              "type": "variable",
              "value": "amount"
            },
            "attemptNumber": {
              "type": "variable",
              "value": "${attempt}"
            },
            "retryCount": {
              "type": "variable",
              "value": "retryCount"
            }
          },
          "outputs": {
            "retryValid": {
              "type": "variable",
              "value": "isValid"
            },
            "approvedRetries": {
              "type": "variable",
              "value": "approved"
            },
            "paymentMethod": {
              "type": "variable",
              "value": "newPaymentMethod"
            }
          }
        },
        "generateReceiptTask": {
          "inputs": {
            "orderId": {
              "type": "variable",
              "value": "orderId"
            },
            "amount": {
              "type": "variable",
              "value": "amount"
            },
            "paymentDetails": {
              "type": "variable",
              "value": "paymentDetails"
            },
            "customerEmail": {
              "type": "variable",
              "value": "customerEmail"
            }
          },
          "outputs": {
            "receiptNumber": {
              "type": "variable",
              "value": "receiptId"
            },
            "receiptUrl": {
              "type": "variable",
              "value": "downloadUrl"
            }
          }
        },
        "notifyAccountingTask": {
          "inputs": {
            "orderId": {
              "type": "variable",
              "value": "orderId"
            },
            "amount": {
              "type": "variable",
              "value": "amount"
            },
            "paymentDetails": {
              "type": "variable",
              "value": "paymentDetails"
            },
            "receiptNumber": {
              "type": "variable",
              "value": "receiptNumber"
            },
            "paymentStatus": {
              "type": "variable",
              "value": "paymentStatus"
            }
          }
        }
      },
      "constants": {
        "validatePaymentMethodTask": {
          "paymentValidatorApi": {
            "value": "https://api.paymentvalidator.com/v1"
          },
          "supportedMethods": {
            "value": "CREDIT_CARD,DEBIT_CARD,PAYPAL,BANK_TRANSFER"
          }
        },
        "processPaymentTask": {
          "paymentGateway": {
            "value": "https://api.stripe.com/v1"
          },
          "apiKey": {
            "value": "${STRIPE_API_KEY}"
          },
          "timeout": {
            "value": "30000"
          },
          "currency": {
            "value": "USD"
          }
        },
        "generateReceiptTask": {
          "receiptTemplate": {
            "value": "STANDARD_RECEIPT"
          },
          "receiptPrefix": {
            "value": "RCP-"
          }
        },
        "notifyAccountingTask": {
          "accountingSystem": {
            "value": "https://accounting.company.com/api"
          },
          "webhookUrl": {
            "value": "${ACCOUNTING_WEBHOOK_URL}"
          }
        }
      }
    }
  }
}
